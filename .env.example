# Copy this file to .env.local and fill in your real key.
# .env.local is gitignored.
#
# NOTE: Vite inlines VITE_* env vars into the client bundle at build time.
# Do NOT use a real production key if you plan to deploy this app publicly —
# anyone can extract it from the built JS. This is local-dev / demo only.

VITE_ANTHROPIC_API_KEY=sk-ant-replace-me
