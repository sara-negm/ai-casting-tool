# Copy this file to .env.local and fill in your real key.
# .env.local is gitignored.
#
# This key is READ SERVER-SIDE ONLY — by the Vite dev middleware in vite.config.js
# during local dev, and by the Vercel Edge function in api/claude.ts in production.
# It is NEVER inlined into the client bundle, so it stays out of the browser.
#
# In production (Vercel), set ANTHROPIC_API_KEY in:
#   Project → Settings → Environment Variables
# then trigger a redeploy.

ANTHROPIC_API_KEY=sk-ant-replace-me
